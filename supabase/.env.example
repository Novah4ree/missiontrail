# Edge Function secrets. Copy to supabase/.env.local for local development only.
# Generate RELIC_SPAWN_HMAC_SECRET with at least 32 random bytes.
RELIC_SPAWN_HMAC_SECRET=

# Server-only Geoapify key. Set with `supabase secrets set GEOAPIFY_API_KEY=...`.
# Never rename this to EXPO_PUBLIC_GEOAPIFY_API_KEY.
GEOAPIFY_API_KEY=
TRAIL_DISCOVERY_RATE_LIMIT_PER_MINUTE=20

# Optional server-only overrides. Do not rename these to EXPO_PUBLIC_*.
RELIC_SPAWN_WINDOW_MINUTES=30
RELIC_SEARCH_RADIUS_MILES=10
RELIC_SEARCH_RADIUS_METERS=16093.44
RELIC_TARGET_REVEAL_RADIUS_METERS=4.57
RELIC_FALLBACK_REVEAL_RADIUS_METERS=9
RELIC_NEARBY_SEARCH_RADIUS_FEET=10
RELIC_REQUIRED_ACCURATE_READINGS=3
RELIC_MAX_ACCEPTABLE_GPS_ACCURACY_METERS=12
RELIC_RARE_DISTANCE_MILES=5
RELIC_RARE_DISTANCE_METERS=8046.72
RELIC_LEGENDARY_DISTANCE_MILES=10
RELIC_LEGENDARY_DISTANCE_METERS=16093.44
RELIC_DAILY_MISSION_OVERRIDE_ENABLED=true
RELIC_EXPIRATION_GRACE_PERIOD_SECONDS=120
RELIC_CLUE_DISTANCE_BANDS_METERS=500,200,75
RELIC_CANDIDATES_PER_WINDOW=6
RELIC_MIN_CANDIDATE_SPACING_METERS=250
RELIC_REGION_GEOHASH_PRECISION=5
RELIC_FIELD_RATE_LIMIT_PER_MINUTE=12

# Keep false in production. When false, the server returns no relics unless
# trusted pedestrian/public POIs have been loaded and verified.
RELIC_ALLOW_UNVERIFIED_SPAWNS=false

# Verified daily movement. Health syncing stays off until the native bridge and
# platform permission strings are included in a development build.
RELIC_DISTANCE_RATE_LIMIT_PER_MINUTE=10
RELIC_MAX_MOVEMENT_SPEED_METERS_PER_SECOND=8.9408
RELIC_MAX_OFFLINE_SAMPLE_AGE_HOURS=24
RELIC_HEALTH_SYNC_ENABLED=false

# Development only: both must be set, and IDs must never include production users.
RELIC_ALLOW_DEVELOPMENT_DISTANCE_MOCK=false
RELIC_ALLOW_DEVELOPMENT_TEST_RELIC=false
RELIC_DEVELOPMENT_USER_IDS=
RELIC_PROXIMITY_VERIFICATIONS_PER_MINUTE=12
RELIC_COLLECTION_ATTEMPTS_PER_MINUTE=6
