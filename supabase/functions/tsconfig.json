{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true
  },
  "include": ["**/*.ts", "deno.d.ts"],
  "exclude": ["**/*.test.ts"]
}

